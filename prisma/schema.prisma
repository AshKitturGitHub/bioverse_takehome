// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id                      Int                       @id @default(autoincrement())
  username                String                    @unique
  password                String
  role                    Role
  answers                 Answer[]
  questionnaireCompletions QuestionnaireCompletion[]

  @@map("users")
}

model Questionnaire {
  id                      Int                       @id
  name                    String                    @unique
  questionnaireQuestions  QuestionnaireQuestion[]
  questionnaireCompletions QuestionnaireCompletion[]

  @@map("questionnaires")
}

model Question {
  id                     Int                     @id
  type                   String
  prompt                 String
  options                Json?
  allowsMultiple         Boolean                 @default(false)
  raw                    Json
  answers                Answer[]
  questionnaireQuestions QuestionnaireQuestion[]

  @@map("questions")
}

model QuestionnaireQuestion {
  id              Int           @id
  questionnaireId Int
  questionId      Int
  priority        Int
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  question        Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionnaireId, questionId])
  @@index([questionnaireId, priority])
  @@map("questionnaire_questions")
}

model Answer {
  id         Int      @id @default(autoincrement())
  userId     Int
  questionId Int
  value      Json
  answeredAt DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([questionId])
  @@map("answers")
}

model QuestionnaireCompletion {
  id              Int           @id @default(autoincrement())
  userId          Int
  questionnaireId Int
  completedAt     DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)

  @@unique([userId, questionnaireId])
  @@index([userId])
  @@map("questionnaire_completions")
}
